   "source": [
    "# Join supermarkets to Sub-ICB areas via postcode\n",
    "# First standardise postcode format to match NSPL\n",
    "df_geo['postcode_clean'] = df_geo['postcode'].str.strip().str.upper()\n",
    "nspl_slim = nspl[['pcds', 'sicbl26cd']].copy()\n",
    "nspl_slim['pcds'] = nspl_slim['pcds'].str.strip().str.upper()\n",
    "\n",
    "# Join\n",
    "df_geo_sicbl = df_geo.merge(nspl_slim, left_on='postcode_clean', right_on='pcds', how='left')\n",
    "\n",
    "print(f\"Total supermarkets: {len(df_geo)}\")\n",
    "print(f\"Matched to Sub-ICB: {df_geo_sicbl['sicbl26cd'].notna().sum()}\")\n",
    "print(f\"Unmatched: {df_geo_sicbl['sicbl26cd'].isna().sum()}\")\n",
    "\n",
    "# Now join lookup to get old CCG code (SICBL26CDH) for matching to prescribing data\n",
    "lookup_slim = lookup[['SICBL26CD', 'SICBL26CDH']].drop_duplicates()\n",
    "\n",
    "df_geo_sicbl = df_geo_sicbl.merge(\n",
    "    lookup_slim,\n",
    "    left_on='sicbl26cd', right_on='SICBL26CD', how='left'\n",
    ")\n",
    "\n",
    "print(f\"\\nMatched to CCG code: {df_geo_sicbl['SICBL26CDH'].notna().sum()}\")\n",
    "\n",
    "# Calculate retail accessibility score per Sub-ICB area\n",
    "df_retail_agg = df_geo_sicbl.groupby('SICBL26CDH').agg(\n",
    "    total_stores=('gf_weight', 'count'),\n",
    "    weighted_stores=('gf_weight', 'sum'),\n",
    "    quality_stores=('gf_weight', lambda x: (x == 2).sum()),\n",
    "    regular_stores=('gf_weight', lambda x: (x == 1).sum()),\n",
    "    budget_stores=('gf_weight', lambda x: (x == 0).sum()),\n",
    ").reset_index()\n",
    "\n",
    "# Calculate accessibility score as weighted stores per total stores\n",
    "df_retail_agg['retail_accessibility_score'] = (\n",
    "    df_retail_agg['weighted_stores'] / df_retail_agg['total_stores']\n",
    ")\n",
    "\n",
    "print(f\"\\nRetail aggregated: {df_retail_agg.shape}\")\n",
    "print(df_retail_agg.head(3))\n",
    "print(f\"\\nAccessibility score stats:\")\n",
    "print(df_retail_agg['retail_accessibility_score'].describe())"
   ]
  },
