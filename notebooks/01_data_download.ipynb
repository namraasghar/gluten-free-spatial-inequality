   ],
   "source": [
    "# 2. Load lookup and IMD, aggregate IMD to Sub-ICB level\n",
    "lookup = pd.read_csv(r'C:\\Users\\namra\\gluten-free-spatial-inequality\\data\\raw\\lsoa_to_sicbl_lookup.csv')\n",
    "\n",
    "df_imd = pd.read_csv(\n",
    "    r'C:\\Users\\namra\\gluten-free-spatial-inequality\\data\\raw\\imd_2025_file7.csv')\n",
    "\n",
    "# Rename IMD columns for easier handling\n",
    "df_imd = df_imd.rename(columns={\n",
    "    'LSOA code (2021)': 'LSOA21CD',\n",
    "    'Index of Multiple Deprivation (IMD) Score': 'imd_score',\n",
    "    'Income Score (rate)': 'income_score',\n",
    "    'Employment Score (rate)': 'employment_score',\n",
    "    'Health Deprivation and Disability Score': 'health_score',\n",
    "    'Education, Skills and Training Score': 'education_score',\n",
    "    'Barriers to Housing and Services Score': 'barriers_score',\n",
    "    'Crime Score': 'crime_score',\n",
    "    'Living Environment Score': 'living_env_score'\n",
    "})\n",
    "\n",
    "# Keep only what we need\n",
    "df_imd_slim = df_imd[['LSOA21CD', 'imd_score', 'income_score', 'employment_score',\n",
    "                        'health_score', 'education_score', 'barriers_score',\n",
    "                        'crime_score', 'living_env_score']]\n",
    "\n",
    "# Join IMD to lookup to get Sub-ICB codes\n",
    "df_imd_lookup = df_imd_slim.merge(\n",
    "    lookup[['LSOA21CD', 'SICBL26CDH', 'SICBL26NM']],\n",
    "    on='LSOA21CD', how='left'\n",
    ")\n",
    "\n",
    "print(f\"IMD with lookup: {df_imd_lookup.shape}\")\n",
    "print(f\"Nulls in SICBL26CDH: {df_imd_lookup['SICBL26CDH'].isnull().sum()}\")\n",
    "\n",
    "# Aggregate to Sub-ICB level (mean IMD score across all LSOAs in each area)\n",
    "df_imd_agg = df_imd_lookup.groupby('SICBL26CDH').agg(\n",
