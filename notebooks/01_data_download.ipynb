   "source": [
    "import requests\n",
    "import pandas as pd\n",
    "from datetime import datetime\n",
    "import time\n",
    "import os\n",
    "\n",
    "# Generate list of months from Jan 2019 to Dec 2024\n",
    "dates = pd.date_range(start='2019-01-01', end='2026-05-01', freq='MS')\n",
    "dates = [d.strftime('%Y-%m-%d') for d in dates]\n",
    "\n",
    "print(f\"Downloading data for {len(dates)} months...\")\n",
    "\n",
    "all_data = []\n",
    "\n",
    "for date in dates:\n",
    "    url = f\"https://openprescribing.net/api/1.0/spending_by_org/?code=0904010&org_type=practice&date={date}&format=json\"\n",
    "    try:\n",
    "        response = requests.get(url, timeout=30)\n",
    "        if response.status_code == 200:\n",
    "            data = response.json()\n",
    "            if data:\n",
    "                all_data.extend(data)\n",
    "                print(f\"✓ {date}: {len(data)} practices\")\n",
    "            else:\n",
    "                print(f\"✗ {date}: no data\")\n",
    "        else:\n",
    "            print(f\"✗ {date}: error {response.status_code}\")\n",
    "    except Exception as e:\n",
    "        print(f\"✗ {date}: {e}\")\n",
    "    time.sleep(0.5)  # be polite to the API\n",
    "\n",
    "# Convert to dataframe and save\n",
    "df = pd.DataFrame(all_data)\n",
    "print(f\"\\nTotal rows: {len(df)}\")\n",
    "print(df.head())\n",
    "\n",
    "# Save to raw data folder\n",
    "output_path = r'C:\\Users\\namra\\gluten-free-spatial-inequality\\data\\raw\\gf_prescribing_by_practice.csv'\n",
    "df.to_csv(output_path, index=False)\n",
    "print(f\"\\nSaved to {output_path}\")"
   ]
  },
