   "source": [
    "import pandas as pd\n",
    "\n",
    "# Load all datasets\n",
    "print(\"Loading datasets...\")\n",
    "\n",
    "# 1. Prescribing - aggregate to one row per Sub-ICB (average across all months)\n",
    "df_presc = pd.read_csv(r'C:\\Users\\namra\\gluten-free-spatial-inequality\\data\\raw\\gf_prescribing_subicb.csv')\n",
    "df_presc_agg = df_presc.groupby(['org_id', 'org_name']).agg(\n",
    "    prescribing_rate_mean=('calc_value', 'mean'),\n",
    "    prescribing_rate_median=('calc_value', 'median'),\n",
    "    prescribing_rate_max=('calc_value', 'max'),\n",
    "    months_with_data=('calc_value', 'count'),\n",
    "    months_zero=('calc_value', lambda x: (x == 0).sum())\n",
    ").reset_index()\n",
    "\n",
    "print(f\"Prescribing aggregated: {df_presc_agg.shape}\")\n",
    "print(df_presc_agg.head(3))"
   ]
  },
